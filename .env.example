SLACK_BOT_TOKEN=xoxb-your-bot-token

# Four domain-specific Slack channels. If a domain channel is empty, SLACK_CHANNEL_ID is used as fallback.
SLACK_CHANNEL_DIFFUSION=
SLACK_CHANNEL_EFFICIENT=
SLACK_CHANNEL_RL=
SLACK_CHANNEL_AGENT=
SLACK_CHANNEL_ID=

# Preferred: DeepSeek summary
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat
# Optional custom endpoint (default already works)
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions

# Optional fallback: OpenAI/Codex-compatible model
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional tuning
DIGEST_CONFIG=config/domains.json
TIMEZONE=Asia/Singapore
ARXIV_MAX_RESULTS=2000
HF_MAX_RESULTS=80
HF_MAX_PER_DOMAIN=100
ANALYSIS_MAX_PAPERS=40
DOMAIN_WORKERS=4
REPORT_DIR=reports
DISABLE_LLM=0
