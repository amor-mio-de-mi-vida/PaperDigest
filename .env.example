SLACK_BOT_TOKEN=xoxb-your-bot-token

# Unified Slack channel for the daily Canvas and all domain briefs.
SLACK_CHANNEL_ID=

# Preferred: DeepSeek summary
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat
# Optional custom endpoint (default already works)
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions

# Optional fallback: OpenAI/Codex-compatible model
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional tuning
DIGEST_CONFIG=config/domains.json
TIMEZONE=Asia/Singapore
ARXIV_MAX_RESULTS=2000
ARXIV_PAGE_SIZE=500
ARXIV_REQUEST_DELAY_SECONDS=3.5
ARXIV_RETRIES=6
ARXIV_RETRY_BASE_SECONDS=20
ARXIV_RETRY_MAX_SECONDS=300
HF_MAX_RESULTS=80
HF_MAX_PER_DOMAIN=100
ANALYSIS_MAX_PAPERS=40
DOMAIN_WORKERS=4
REPORT_DIR=reports
DISABLE_LLM=0
UPDATE_ARCHIVE=1
ARCHIVE_DIR=archive
DAILY_FILE_NAME=daily-ai-paper-digest.md
SLACK_RETRIES=4
SLACK_RETRY_BASE_SECONDS=3
SLACK_RETRY_MAX_SECONDS=60
